services:
  postgres:
    image: postgres:16-alpine
    container_name: sqlab-postgres
    environment:
      POSTGRES_DB: sqlab
      POSTGRES_USER: sqlab
      POSTGRES_PASSWORD: sqlab
    ports:
      - "5436:5432"
    volumes:
      - sqlab-postgres-data:/var/lib/postgresql/data
#    networks:
#      - sqlab-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U sqlab"]
      interval: 10s
      timeout: 5s
      retries: 5

