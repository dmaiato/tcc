{
  "name": "sqlab-client",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:pglite": "vitest run --config vitest.config.node.ts src/app/core/pglite.integration.spec.ts"
  },
  "prettier": {
    "printWidth": 100,
